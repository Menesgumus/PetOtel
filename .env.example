POSTGRES_DB=ankara_pet_house
POSTGRES_USER=ankara_pet_house
POSTGRES_PASSWORD=change-this-to-a-secure-password

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5434/ankara_pet_house
# If using Docker internal networking, use:
# SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/ankara_pet_house
SPRING_DATASOURCE_USERNAME=ankara_pet_house
SPRING_DATASOURCE_PASSWORD=change-this-to-a-secure-password

# Admin seed logic - set to true ONLY for the first run or when explicitly resetting the admin password.
# IMPORTANT: After successfully logging in with the new admin credentials, change this back to false.
APP_ADMIN_SEED_ENABLED=false
APP_ADMIN_USERNAME=admin
APP_ADMIN_EMAIL=admin@ankarapethouse.com
APP_ADMIN_PASSWORD=change-this-admin-password

# JWT Secret - generate a secure random 64-character string
APP_JWT_SECRET=change-this-to-a-random-64-character-string-for-jwt-signing
APP_JWT_EXPIRATION_MS=86400000

APP_FRONTEND_ORIGIN=http://localhost:3000
APP_UPLOAD_DIR=./uploads
